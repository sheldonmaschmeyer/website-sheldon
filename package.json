{
  "name": "sheldon-resume-vue3",
  "version": "1.0.0",
  "private": true,
  "description": "A Bootstrap Vue3 & Vite resume/CV based on Start Bootstrap Vue2 Resume template by webdevsuperfast.",
  "author": "Sheldon Maschmeyer <sheldon@maschmeyer.ca>",
