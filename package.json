    "@fortawesome/vue-fontawesome": "^3.1.2",
    "@popperjs/core": "^2.11.8",
    "@vue/compat": "^3.5.22",
    "@vueuse/core": "^14.0.0",
    "bootstrap": "^5.3.8",
    "core-js": "^3.46.0",
    "floating-vue": "^5.2.2",
    "smooth-scroll": "^16.1.3",
    "typescript": "^5.9.3",
    "vue": "^3.5.22",
    "vue-responsive-video-background-player": "^2.4.1",
    "vue-window-size": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
