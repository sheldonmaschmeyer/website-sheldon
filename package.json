    "@popperjs/core": "^2.11.8",
    "@vue/compat": "^3.5.34",
    "@vueuse/core": "^14.3.0",
    "bootstrap": "^5.3.8",
    "core-js": "^3.49.0",
    "floating-vue": "^5.2.2",
    "smooth-scroll": "^16.1.3",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vue-responsive-video-background-player": "^2.4.1",
    "vue-window-size": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
